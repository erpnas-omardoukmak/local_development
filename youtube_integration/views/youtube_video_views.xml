<odoo>

    <!-- Action -->
    <record id="youtube_video_action" model="ir.actions.act_window">
        <field name="name">Videos</field>
        <field name="res_model">youtube.video</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="youtube_video_menu"
              name="Videos"
              parent="youtube_root_menu"
              action="youtube_video_action"/>

    <!-- TREE -->
    <record id="youtube_video_list" model="ir.ui.view">
        <field name="name">youtube.video.list</field>
        <field name="model">youtube.video</field>
        <field name="arch" type="xml">
            <list>
                <field name="thumbnail" widget="image" options="{'size': [24, 24], 'img_class': 'rounded-3'}" width="30" nolabel="1"/>
                <field name="name"/>
                <field name="channel_title"/>
                <field name="published_at"/>
                <field name="duration"/>
                <field name="view_count"/>
                <field name="like_count"/>
                <field name="comment_count"/>
                <field name="privacy_status"/>
                <field name="upload_status"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="youtube_video_form" model="ir.ui.view">
        <field name="name">youtube.video.form</field>
        <field name="model">youtube.video</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_upload_video_resumable"
                            type="object"
                            string="Upload to YouTube"
                            class="btn-primary"/>
                    <button name="action_upload_thumbnail"
                            type="object"
                            string="Upload Thumbnail"
                            class="btn-secondary"
                            invisible="not custom_thumbnail or not youtube_id"/>
                    <button name="action_fetch_video_by_id"
                            type="object"
                            string="Fetch from YouTube"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Video title"/></h1>
                        <field name="youtube_url" widget="url" readonly="1" invisible="not youtube_id"/>
                    </div>
                    <group>
                        <group>
                            <field name="youtube_id"/>
                            <field name="playlist_id"/>
                            <field name="channel_title" readonly="1"/>
                            <field name="channel_youtube_id" readonly="1"/>
                            <field name="published_at" readonly="1"/>
                            <field name="thumbnail_url" widget="url"/>
                        </group>
                        <group>
                            <field name="thumbnail" widget="image" class="oe_avatar" nolabel="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Description..."/>
                        </page>

                        <page string="Snippet">
                            <group>
                                <group>
                                    <field name="tags" placeholder="comma, separated, tags"/>
                                    <field name="category_id"/>
                                    <field name="default_language"/>
                                    <field name="default_audio_language"/>
                                </group>
                                <group>
                                    <field name="live_broadcast_content"/>
                                </group>
                            </group>
                        </page>

                        <page string="Status">
                            <group>
                                <group>
                                    <field name="privacy_status"/>
                                    <field name="upload_status" readonly="1"/>
                                    <field name="license"/>
                                    <field name="embeddable"/>
                                    <field name="public_stats_viewable"/>
                                </group>
                                <group>
                                    <field name="made_for_kids"/>
                                    <field name="self_declared_made_for_kids"/>
                                    <field name="publish_at"/>
                                    <field name="is_short" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Statistics">
                            <group>
                                <group>
                                    <field name="view_count"/>
                                    <field name="like_count"/>
                                    <field name="dislike_count"/>
                                </group>
                                <group>
                                    <field name="comment_count"/>
                                    <field name="favorite_count"/>
                                </group>
                            </group>
                        </page>

                        <page string="Content Details">
                            <group>
                                <group>
                                    <field name="duration"/>
                                    <field name="duration_seconds"/>
                                    <field name="definition"/>
                                    <field name="dimension"/>
                                </group>
                                <group>
                                    <field name="caption"/>
                                    <field name="licensed_content"/>
                                    <field name="projection"/>
                                </group>
                            </group>
                        </page>

                        <page string="Topics &amp; Recording">
                            <group>
                                <group>
                                    <field name="recording_date"/>
                                </group>
                                <group>
                                    <field name="topic_categories"/>
                                </group>
                            </group>
                        </page>

                        <page string="Live Streaming"
                              invisible="not scheduled_start_time and not actual_start_time">
                            <group>
                                <group>
                                    <field name="scheduled_start_time"/>
                                    <field name="actual_start_time"/>
                                </group>
                                <group>
                                    <field name="scheduled_end_time"/>
                                    <field name="actual_end_time"/>
                                    <field name="concurrent_viewers"/>
                                </group>
                            </group>
                        </page>

                        <page string="Upload">
                            <group>
                                <group>
                                    <field name="video_file_path"/>
                                    <field name="upload_progress"/>
                                    <field name="file_size"/>
                                </group>
                                <group>
                                    <field name="custom_thumbnail"
                                           filename="custom_thumbnail_filename"
                                           widget="binary"/>
                                    <field name="custom_thumbnail_filename" invisible="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="youtube_video_search" model="ir.ui.view">
        <field name="name">youtube.video.search</field>
        <field name="model">youtube.video</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="youtube_id"/>
                <field name="channel_title"/>
                <field name="playlist_id"/>
                <field name="tags"/>
                <filter string="Shorts" name="shorts" domain="[('is_short', '=', True)]"/>
                <filter string="Public" name="public" domain="[('privacy_status', '=', 'public')]"/>
                <filter string="Private" name="private" domain="[('privacy_status', '=', 'private')]"/>
                <filter string="Scheduled" name="scheduled" domain="[('publish_at', '!=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Channel" name="by_channel" context="{'group_by': 'channel_title'}"/>
                    <filter string="Playlist" name="by_playlist" context="{'group_by': 'playlist_id'}"/>
                    <filter string="Privacy" name="by_privacy" context="{'group_by': 'privacy_status'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
