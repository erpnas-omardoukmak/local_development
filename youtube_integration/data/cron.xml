<odoo>
    <record id="youtube_analytics_cron" model="ir.cron">
        <field name="name">YouTube Analytics Sync</field>
        <field name="model_id" ref="model_google_account"/>
        <field name="state">code</field>
        <field name="code">model.search([]).cron_fetch_analytics()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
    </record>
</odoo>