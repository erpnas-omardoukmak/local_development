<odoo>

    <!-- Action -->
    <record id="youtube_playlist_action" model="ir.actions.act_window">
        <field name="name">Programs (Playlists)</field>
        <field name="res_model">youtube.playlist</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="youtube_playlist_menu"
              name="Programs (Playlists)"
              parent="youtube_root_menu"
              action="youtube_playlist_action"/>

    <!-- LIST -->
    <record id="youtube_playlist_list" model="ir.ui.view">
        <field name="name">youtube.playlist.list</field>
        <field name="model">youtube.playlist</field>
        <field name="arch" type="xml">
            <list>
                <field name="program_code"/>
                <field name="program_name"/>
                <field name="name"/>
                <field name="channel_id"/>
                <field name="video_count" string="Episodes"/>
                <field name="short_count" string="Shorts"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="youtube_playlist_form" model="ir.ui.view">
        <field name="name">youtube.playlist.form</field>
        <field name="model">youtube.playlist</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_fetch_playlist_by_id"
                            type="object"
                            string="Fetch from YouTube"
                            class="btn-secondary"/>
                    <button name="action_sync_videos"
                            type="object"
                            string="Sync Videos"
                            class="btn-primary"/>
                </header>

                <sheet>
                    <group>
                        <group string="Program">
                            <field name="program_code"/>
                            <field name="program_name"/>
                        </group>
                        <group string="YouTube Playlist">
                            <field name="name"/>
                            <field name="youtube_id"/>
                            <field name="channel_id"/>
                            <field name="status"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>

                    <notebook>
                        <page string="Episodes">
                            <field name="video_ids">
                                <list>
                                    <field name="week_label"/>
                                    <field name="name"/>
                                    <field name="published_at"/>
                                    <field name="view_count" string="Views"/>
                                    <field name="like_count" string="Likes"/>
                                    <field name="short_count" string="Shorts"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="youtube_playlist_search" model="ir.ui.view">
        <field name="name">youtube.playlist.search</field>
        <field name="model">youtube.playlist</field>
        <field name="arch" type="xml">
            <search>
                <field name="program_code"/>
                <field name="program_name"/>
                <field name="name"/>
                <field name="youtube_id"/>
                <field name="channel_id"/>
                <group>
                    <filter string="Channel" name="by_channel" context="{'group_by': 'channel_id'}"/>
                    <filter string="Program" name="by_program" context="{'group_by': 'program_code'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
