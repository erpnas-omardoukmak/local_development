<odoo>

    <!-- Action -->
    <record id="youtube_channel_action" model="ir.actions.act_window">
        <field name="name">Channels</field>
        <field name="res_model">youtube.channel</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="youtube_channel_menu"
              name="Channels"
              parent="youtube_root_menu"
              action="youtube_channel_action"/>

    <!-- TREE -->
    <record id="youtube_channel_list" model="ir.ui.view">
        <field name="name">youtube.channel.list</field>
        <field name="model">youtube.channel</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="subscriber_count"/>
                <field name="view_count"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="youtube_channel_form" model="ir.ui.view">
        <field name="name">youtube.channel.form</field>
        <field name="model">youtube.channel</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sync_playlists"
                            type="object"
                            string="Sync Playlists"
                            class="btn-primary"/>
                    <button name="action_fetch_channel_by_id"
                            type="object"
                            string="Fetch from YouTube"
                            class="btn-secondary"/>
                </header>

                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="youtube_id"/>
                        <field name="google_account_id"/>
                    </group>

                    <group>
                        <field name="subscriber_count"/>
                        <field name="view_count"/>
                        <field name="status"/>
                    </group>

                    <notebook>
                        <page string="Playlists">
                            <field name="playlist_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

</odoo>