<odoo>

    <!-- Action -->
    <record id="youtube_video_action" model="ir.actions.act_window">
        <field name="name">Videos</field>
        <field name="res_model">youtube.video</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="youtube_video_menu"
              name="Videos"
              parent="youtube_root_menu"
              action="youtube_video_action"/>

    <!-- TREE -->
    <record id="youtube_video_list" model="ir.ui.view">
        <field name="name">youtube.video.list</field>
        <field name="model">youtube.video</field>
        <field name="arch" type="xml">
            <list>
                <field name="thumbnail" widget="image" options="{'size': [24, 24], 'img_class': 'rounded-3'}" width="30" nolabel="1"/>
                <field name="name"/>
                <field name="view_count"/>
                <field name="like_count"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="youtube_video_form" model="ir.ui.view">
        <field name="name">youtube.video.form</field>
        <field name="model">youtube.video</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_upload_video_resumable"
                            type="object"
                            string="Upload to YouTube"
                            class="btn-primary"/>
                    <button name="action_fetch_video_by_id"
                            type="object"
                            string="Fetch from YouTube"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="youtube_id"/>
                            <field name="playlist_id"/>
                            <field name="description"/>
                            <field name="thumbnail_url" widget="url"/>
                        </group>

                        <group>
                            <field name="thumbnail" widget="image" class="oe_avatar" nolabel="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Statistics">
                            <group>
                                <group>
                                    <field name="view_count"/>
                                    <field name="like_count"/>
                                    <field name="status"/>
                                    <field name="is_short"/>
                                </group>
                            </group>
                        </page>
                        <page string="Uplaoding info">
                            <group>
                                <group>
                                    <field name="video_file_path"/>
                                    <field name="upload_progress"/>
                                    <field name="file_size"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>