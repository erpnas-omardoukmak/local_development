<odoo>

    <!-- Action -->
    <record id="youtube_short_action" model="ir.actions.act_window">
        <field name="name">Shorts (Reels)</field>
        <field name="res_model">youtube.short</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="youtube_short_menu"
              name="Shorts (Reels)"
              parent="youtube_root_menu"
              action="youtube_short_action"
              sequence="15"/>

    <!-- LIST -->
    <record id="youtube_short_list" model="ir.ui.view">
        <field name="name">youtube.short.list</field>
        <field name="model">youtube.short</field>
        <field name="arch" type="xml">
            <list>
                <field name="thumbnail" widget="image" options="{'size': [24, 24], 'img_class': 'rounded-3'}" width="30" nolabel="1"/>
                <field name="program_code"/>
                <field name="video_id"/>
                <field name="reel_number"/>
                <field name="name"/>
                <field name="asset_code" optional="hide"/>
                <field name="published_at"/>
                <field name="duration"/>
                <field name="view_count" string="Views"/>
                <field name="like_count" string="Likes"/>
                <field name="comment_count" string="Comments"/>
                <field name="shares" optional="hide"/>
                <field name="saves" optional="hide"/>
                <field name="reach" optional="hide"/>
                <field name="watch_time_min" optional="hide"/>
                <field name="engagement_rate" widget="percentage" optional="hide"/>
                <field name="privacy_status"/>
                <field name="upload_status" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="youtube_short_form" model="ir.ui.view">
        <field name="name">youtube.short.form</field>
        <field name="model">youtube.short</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_upload_thumbnail"
                            type="object"
                            string="Upload Thumbnail"
                            class="btn-secondary"
                            invisible="not custom_thumbnail or not youtube_id"/>
                    <button name="action_fetch_video_by_id"
                            type="object"
                            string="Fetch from YouTube"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Short title"/></h1>
                        <field name="youtube_url" widget="url" readonly="1" invisible="not youtube_id"/>
                    </div>
                    <group>
                        <group>
                            <field name="video_id"/>
                            <field name="reel_number"/>
                            <field name="youtube_id"/>
                            <field name="program_code" readonly="1"/>
                            <field name="program_name" readonly="1"/>
                            <field name="base_episode_code" readonly="1"/>
                            <field name="published_at" readonly="1"/>
                            <field name="thumbnail_url" widget="url"/>
                        </group>
                        <group>
                            <field name="thumbnail" widget="image" class="oe_avatar" nolabel="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>

                        <page string="Damma Dashboard">
                            <group>
                                <group string="Coding">
                                    <field name="asset_code"/>
                                    <field name="display_name"/>
                                    <field name="week_label"/>
                                    <field name="week_number"/>
                                    <field name="year"/>
                                </group>
                                <group string="Content / Platform">
                                    <field name="content_type"/>
                                    <field name="platform"/>
                                    <field name="platform_format"/>
                                    <field name="publish_day"/>
                                </group>
                            </group>
                            <group>
                                <group string="Editorial">
                                    <field name="topic"/>
                                    <field name="guest"/>
                                    <field name="hook"/>
                                </group>
                                <group string="Engagement / Reach">
                                    <field name="reach"/>
                                    <field name="shares"/>
                                    <field name="saves"/>
                                    <field name="followers_gained"/>
                                    <field name="engagement_rate" widget="percentage"/>
                                </group>
                            </group>
                            <group string="Watch Performance">
                                <group>
                                    <field name="watch_time_min"/>
                                    <field name="avg_view_duration_sec"/>
                                </group>
                                <group>
                                    <field name="avg_pct_viewed"/>
                                    <field name="retention_30s_pct"/>
                                </group>
                            </group>
                        </page>

                        <page string="Snippet">
                            <group>
                                <group>
                                    <field name="tags"/>
                                    <field name="category_id"/>
                                    <field name="default_language"/>
                                    <field name="default_audio_language"/>
                                </group>
                                <group>
                                    <field name="channel_title" readonly="1"/>
                                    <field name="channel_youtube_id" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Status">
                            <group>
                                <group>
                                    <field name="privacy_status"/>
                                    <field name="upload_status" readonly="1"/>
                                    <field name="license"/>
                                    <field name="embeddable"/>
                                    <field name="public_stats_viewable"/>
                                </group>
                                <group>
                                    <field name="made_for_kids"/>
                                    <field name="self_declared_made_for_kids"/>
                                    <field name="publish_at"/>
                                </group>
                            </group>
                        </page>

                        <page string="Statistics (YouTube)">
                            <group>
                                <group>
                                    <field name="view_count"/>
                                    <field name="like_count"/>
                                    <field name="dislike_count"/>
                                </group>
                                <group>
                                    <field name="comment_count"/>
                                    <field name="favorite_count"/>
                                </group>
                            </group>
                        </page>

                        <page string="Content Details">
                            <group>
                                <group>
                                    <field name="duration"/>
                                    <field name="duration_seconds"/>
                                    <field name="definition"/>
                                </group>
                                <group>
                                    <field name="caption"/>
                                    <field name="licensed_content"/>
                                </group>
                            </group>
                        </page>

                        <page string="Upload">
                            <group>
                                <group>
                                    <field name="video_file_path"/>
                                    <field name="upload_progress"/>
                                    <field name="file_size"/>
                                </group>
                                <group>
                                    <field name="custom_thumbnail"
                                           filename="custom_thumbnail_filename"
                                           widget="binary"/>
                                    <field name="custom_thumbnail_filename" invisible="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="youtube_short_search" model="ir.ui.view">
        <field name="name">youtube.short.search</field>
        <field name="model">youtube.short</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="youtube_id"/>
                <field name="asset_code"/>
                <field name="program_code"/>
                <field name="program_name"/>
                <field name="video_id"/>
                <field name="topic"/>
                <field name="guest"/>
                <field name="tags"/>
                <filter string="Public" name="public" domain="[('privacy_status', '=', 'public')]"/>
                <filter string="Private" name="private" domain="[('privacy_status', '=', 'private')]"/>
                <filter string="Scheduled" name="scheduled" domain="[('publish_at', '!=', False)]"/>
                <group>
                    <filter string="Program" name="by_program" context="{'group_by': 'program_code'}"/>
                    <filter string="Episode" name="by_video" context="{'group_by': 'video_id'}"/>
                    <filter string="Year" name="by_year" context="{'group_by': 'year'}"/>
                    <filter string="Week" name="by_week" context="{'group_by': 'week_label'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
