<odoo>
    <record id="youtube_short_upload_wizard_form" model="ir.ui.view">
        <field name="name">youtube.short.upload.wizard.form</field>
        <field name="model">youtube.short.upload.wizard</field>
        <field name="arch" type="xml">
            <form string="Upload Short">
                <sheet>
                    <group>
                        <group>
                            <field name="parent_video_id"/>
                            <field name="reel_number"/>
                            <field name="google_account_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="video_file_path"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Snippet">
                            <group>
                                <group>
                                    <field name="title"/>
                                    <field name="tags"/>
                                    <field name="category_id"/>
                                </group>
                                <group>
                                    <field name="default_language"/>
                                    <field name="default_audio_language"/>
                                </group>
                            </group>
                            <group string="Description">
                                <field name="description" nolabel="1"/>
                            </group>
                            <group string="Editorial">
                                <group>
                                    <field name="topic"/>
                                    <field name="guest"/>
                                </group>
                                <group>
                                    <field name="hook"/>
                                </group>
                            </group>
                        </page>
                        <page string="Status">
                            <group>
                                <group>
                                    <field name="privacy_status"/>
                                    <field name="license"/>
                                    <field name="embeddable"/>
                                </group>
                                <group>
                                    <field name="public_stats_viewable"/>
                                    <field name="self_declared_made_for_kids"/>
                                    <field name="publish_at"/>
                                </group>
                            </group>
                        </page>
                        <page string="Thumbnail">
                            <group>
                                <field name="custom_thumbnail"
                                       filename="custom_thumbnail_filename"
                                       widget="binary"/>
                                <field name="custom_thumbnail_filename" invisible="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_upload"
                            type="object"
                            string="Upload Short"
                            class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="youtube_short_upload_wizard_action" model="ir.actions.act_window">
        <field name="name">Upload Short</field>
        <field name="res_model">youtube.short.upload.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="youtube_short_upload_menu"
              name="Upload Short"
              parent="youtube_root_menu"
              action="youtube_short_upload_wizard_action"
              sequence="22"/>
</odoo>
