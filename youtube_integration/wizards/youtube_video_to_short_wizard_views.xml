<odoo>
    <record id="youtube_video_to_short_wizard_form" model="ir.ui.view">
        <field name="name">youtube.video.to.short.wizard.form</field>
        <field name="model">youtube.video.to.short.wizard</field>
        <field name="arch" type="xml">
            <form string="Convert to Short">
                <sheet>
                    <group>
                        <field name="source_video_id" readonly="1"/>
                        <field name="parent_video_id"/>
                        <field name="reel_number"/>
                        <field name="delete_source"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_convert"
                            type="object"
                            string="Convert"
                            class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
